# ─── Required ────────────────────────────────────────────────────────────────

# Alchemy SDK — used for token balances, transactions, ENS resolution
# Get your key at: https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Anthropic Claude API — used for AI narrative generation
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Optional (but recommended) ──────────────────────────────────────────────

# DeBank Pro API — used for protocol detection and portfolio valuation
# Without this, the app falls back to mock protocol data
# Get your key at: https://cloud.debank.com
DEBANK_API_KEY=your_debank_api_key_here

# Etherscan API — used as a fallback for wallet age detection
# Without this, wallet age falls back to Alchemy data only
# Get your key at: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here
