# ─── Required ────────────────────────────────────────────────────────────────

# Alchemy SDK — used for token balances, transactions, ENS resolution
# Get your key at: https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Anthropic Claude API — used for AI narrative generation
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────

# Etherscan API — used as a fallback for wallet age detection
# Without this, wallet age falls back to Alchemy data only
# Get your key at: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# CoinGecko Pro API — used to enrich token USD prices
# Without this, the app uses the free CoinGecko API (rate-limited)
# Get your key at: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=your_coingecko_api_key_here

# Helius API — used for Solana wallet analysis (balances, transactions, NFTs)
# Without this, Solana addresses return an empty profile
# Get your free key at: https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here
